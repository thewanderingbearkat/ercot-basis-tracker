# Copy this file to .env and fill in real values. Never commit .env.
# On Render, set these as environment variables in the service dashboard.

# Tenaska / Pharos PTP Energy API (ERCOT data)
TENASKA_API_USER=your-tenaska-username
TENASKA_API_PASSWORD=your-tenaska-password

# Pharos AMS API (NWOH / PJM data)
PHAROS_API_TOKEN=your-pharos-api-token

# Flask session signing key. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-random-32-byte-hex-string

# Dashboard login password
DASHBOARD_PASSWORD=pick-a-strong-password
