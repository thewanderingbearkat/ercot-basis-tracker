# Copy this file to .env and fill in real values. Never commit .env.
# On Render, set these as environment variables in the service dashboard.

# Tenaska / Pharos PTP Energy API (ERCOT data)
TENASKA_API_USER=your-tenaska-username
TENASKA_API_PASSWORD=your-tenaska-password

# Pharos AMS API (NWOH / PJM data)
PHAROS_API_TOKEN=your-pharos-api-token

# Flask session signing key. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-random-32-byte-hex-string

# Dashboard login password
DASHBOARD_PASSWORD=pick-a-strong-password

# Vaisala XWeather (hail predictor trial) -- from the XWeather trial dashboard
XWEATHER_CLIENT_ID=your-xweather-client-id
XWEATHER_CLIENT_SECRET=your-xweather-client-secret

# Snowflake (Yes Energy ERCOT dataset) -- constraint map
SNOWFLAKE_USER=your-snowflake-user
SNOWFLAKE_ACCOUNT=your-account.region.cloud
SNOWFLAKE_WAREHOUSE=your-warehouse
# Auth: prefer key-pair (no MFA/Duo, required for headless use on Render).
# Set ONE of these. If a key is set it is used instead of the password.
#   Local:  SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
#   Render: SNOWFLAKE_PRIVATE_KEY=<full PEM contents of the private key>
# SNOWFLAKE_PASSWORD triggers MFA if the account enforces it -- avoid in prod.
SNOWFLAKE_PASSWORD=your-snowflake-password
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/your/rsa_key.p8
